rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 0. Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // 3. Global Helpers
    function isSignedIn() { return request.auth != null; }
    function isOwner(userId) { return isSignedIn() && request.auth.uid == userId; }
    function isEmailVerified() { return isSignedIn() && request.auth.token.email_verified == true; }
    function isAdmin() { return isSignedIn() && exists(/databases/$(database)/documents/admins/$(request.auth.uid)); }
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }
    function isValidId(id) { return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); }

    // 2. Validation Helpers
    function isValidUser(data) {
      return data.keys().hasAll(['uid', 'email', 'role']) &&
             data.uid == request.auth.uid &&
             data.email is string &&
             data.role in ['reporter', 'admin'] &&
             data.keys().size() <= 6;
    }

    function isValidMissingPerson(data) {
      return data.keys().hasAll(['reporterId', 'fullName', 'status', 'createdAt']) &&
             data.reporterId == request.auth.uid &&
             data.fullName is string && data.fullName.size() <= 100 &&
             data.status in ['ACTIVE', 'POSSIBLE_MATCH', 'FOUND', 'CLOSED', 'POLICE_HANDLED'] &&
             data.createdAt == request.time &&
             (data.get('age', 0) is int) &&
             (data.get('photoUrl', '') is string) &&
             data.keys().size() <= 35;
    }

    function isValidFoundReport(data) {
      return data.keys().hasAll(['missingPersonId', 'helperName', 'createdAt']) &&
             isValidId(data.missingPersonId) &&
             data.helperName is string && data.helperName.size() <= 100 &&
             data.createdAt == request.time &&
             data.keys().size() <= 10;
    }

    // --- Collections ---

    // Users
    match /users/{userId} {
      allow get: if isSignedIn();
      allow list: if isAdmin();
      allow create: if isOwner(userId) && isValidUser(incoming());
      allow update: if isOwner(userId) && isValidUser(incoming()) && 
                    incoming().diff(existing()).affectedKeys().hasOnly(['displayName', 'photoURL', 'updatedAt']);
    }

    // Missing Persons
    match /missing_persons/{personId} {
      // Public read for ACTIVE cases
      allow get: if true;
      allow list: if true && (resource.data.status == 'ACTIVE' || isAdmin() || (isSignedIn() && resource.data.reporterId == request.auth.uid));
      
      allow create: if isEmailVerified() && isValidMissingPerson(incoming());
      allow update: if isEmailVerified() && (
        (isOwner(existing().reporterId) && isValidMissingPerson(incoming()) && (
          // General Update
          incoming().diff(existing()).affectedKeys().hasOnly([
            'fullName', 'nickname', 'age', 'gender', 'photoUrl', 'clothingDescription', 'height', 
            'languageSpoken', 'motherName', 'fatherName', 'siblingNames', 'school', 'village', 
            'locality', 'colony', 'nearbyLandmark', 'lastSeenLocation', 'missingDate', 
            'mentalCondition', 'medicalCondition', 'additionalNotes', 'primaryPhone', 
            'secondaryPhone', 'whatsappNumber', 'rewardAvailable', 'rewardAmount', 'updatedAt', 'status'
          ])
        )) ||
        isAdmin()
      );
      allow delete: if isAdmin() || (isOwner(existing().reporterId) && existing().status == 'CLOSED');
    }

    // Found Reports
    match /found_reports/{reportId} {
      allow get: if isSignedIn() && (
        isOwner(get(/databases/$(database)/documents/missing_persons/$(resource.data.missingPersonId)).data.reporterId) ||
        isAdmin()
      );
      allow list: if isSignedIn() && isAdmin(); // Only admins can see global feed, reporters see via queries or specific lookups
      
      allow create: if true && isValidFoundReport(incoming()); // Anonymous people can report finding someone
      allow update: if isSignedIn() && (
        isOwner(get(/databases/$(database)/documents/missing_persons/$(existing().missingPersonId)).data.reporterId) ||
        isAdmin()
      ) && incoming().diff(existing()).affectedKeys().hasOnly(['status', 'updatedAt']);
    }

    // Admins
    match /admins/{adminId} {
      allow read: if isSignedIn();
      allow write: if false; // Managed via console or service account
    }
  }
}
