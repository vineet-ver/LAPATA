{
  "entities": {
    "User": {
      "title": "User",
      "description": "Registered reporter or admin profile",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "email": { "type": "string" },
        "displayName": { "type": "string" },
        "photoURL": { "type": "string" },
        "role": { "type": "string", "enum": ["reporter", "admin"] },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "email", "role"]
    },
    "MissingPerson": {
      "title": "Missing Person",
      "description": "Comprehensive report of a missing individual",
      "type": "object",
      "properties": {
        "reporterId": { "type": "string" },
        "status": { "type": "string", "enum": ["ACTIVE", "POSSIBLE_MATCH", "FOUND", "CLOSED", "POLICE_HANDLED"] },
        "fullName": { "type": "string" },
        "nickname": { "type": "string" },
        "age": { "type": "integer" },
        "gender": { "type": "string" },
        "photoUrl": { "type": "string" },
        "clothingDescription": { "type": "string" },
        "height": { "type": "string" },
        "languageSpoken": { "type": "string" },
        "motherName": { "type": "string" },
        "fatherName": { "type": "string" },
        "siblingNames": { "type": "string" },
        "school": { "type": "string" },
        "village": { "type": "string" },
        "locality": { "type": "string" },
        "colony": { "type": "string" },
        "nearbyLandmark": { "type": "string" },
        "lastSeenLocation": { "type": "string" },
        "missingDate": { "type": "string", "format": "date" },
        "mentalCondition": { "type": "string" },
        "medicalCondition": { "type": "string" },
        "additionalNotes": { "type": "string" },
        "primaryPhone": { "type": "string" },
        "secondaryPhone": { "type": "string" },
        "whatsappNumber": { "type": "string" },
        "rewardAvailable": { "type": "boolean" },
        "rewardAmount": { "type": "number" },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["reporterId", "fullName", "status", "createdAt"]
    },
    "FoundReport": {
      "title": "Found Report",
      "description": "Report submitted by someone who finds a potential match",
      "type": "object",
      "properties": {
        "missingPersonId": { "type": "string" },
        "helperName": { "type": "string" },
        "helperPhone": { "type": "string" },
        "currentLocation": { "type": "string" },
        "notes": { "type": "string" },
        "photoUrl": { "type": "string" },
        "status": { "type": "string", "enum": ["PENDING", "VERIFIED", "REJECTED"] },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["missingPersonId", "helperName", "createdAt"]
    }
  },
  "firestore": {
    "users": {
      "schema": "User",
      "description": "System users collection"
    },
    "missing_persons": {
      "schema": "MissingPerson",
      "description": "Main collection for missing person reports"
    },
    "found_reports": {
      "schema": "FoundReport",
      "description": "Submissions from helpers"
    }
  }
}
